# ==========================================
# Configurações de Ambiente — Contab Planner
# ==========================================

# URL do seu projeto no Supabase (produção)
SUPABASE_URL=https://<seu-projeto>.supabase.co

# Chaves do Supabase
SUPABASE_ANON_KEY=sua_anon_key_aqui
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# Segurança
# Recomendado: gerar usando `openssl rand -hex 32`
SESSION_SECRET=seu_session_secret_seguro_aqui
PROXY_SECRET=seu_proxy_secret_seguro_aqui

# Integração Mercado Pago (opicional para billing)
MERCADOPAGO_ACCESS_TOKEN=seu_access_token
MERCADOPAGO_WEBHOOK_SECRET=seu_webhook_secret

# URL do Backend (para o frontend Next.js enxergar via Docker)
BACKEND_URL=http://backend:8000
